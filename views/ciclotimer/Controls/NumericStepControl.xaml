<UserControl x:Class="CicloTimer.Views.Controls.NumericStepControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="{Binding Label, ElementName=Root}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="44" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="-"
                    Click="DecreaseButton_Click"
                    MinHeight="34" />
            <Border Grid.Column="1"
                    Margin="8,0"
                    Padding="10,6"
                    Background="#FFFFFFFF"
                    BorderBrush="#FFD8DEE9"
                    BorderThickness="1"
                    CornerRadius="6">
                <TextBlock Text="{Binding Value, ElementName=Root}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold" />
            </Border>
            <Button Grid.Column="2"
                    Content="+"
                    Click="IncreaseButton_Click"
                    MinHeight="34" />
        </Grid>
    </StackPanel>
</UserControl>
