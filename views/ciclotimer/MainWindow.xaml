<Window x:Class="CicloTimer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CicloTimer.Views.Controls"
        Title="{Binding AppTitle}"
        Width="460"
        Height="640"
        MinWidth="420"
        MinHeight="560"
        ResizeMode="CanMinimize"
        Background="#FFF4F7FB"
        Closed="Window_Closed">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#FFE1E7EF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF243044" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9B1C1C" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasValidationError}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="22">
            <TextBlock Text="{Binding AppTitle}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#FF1F2937"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,18" />

            <Border Style="{StaticResource CardStyle}"
                    IsEnabled="{Binding CanEditConfiguration}">
                <StackPanel>
                    <TextBlock Text="{Binding SessionDurationLabel}"
                               Style="{StaticResource CardTitleStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <controls:NumericStepControl Grid.Column="0"
                                                     Label="{Binding MinutesLabel}"
                                                     Value="{Binding CycleMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Minimum="0"
                                                     Maximum="999"
                                                     Step="1" />
                        <controls:NumericStepControl Grid.Column="2"
                                                     Label="{Binding SecondsLabel}"
                                                     Value="{Binding CycleSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Minimum="0"
                                                     Maximum="59"
                                                     Step="1" />
                    </Grid>

                    <Separator Margin="0,16" />

                    <controls:NumericStepControl Label="{Binding FinalAlertDurationLabel}"
                                                 Value="{Binding FinalAlertSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Minimum="0"
                                                 Maximum="60"
                                                 Step="1" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding RemainingTimeLabel}"
                               Style="{StaticResource CardTitleStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding RemainingTimeText}"
                               FontSize="54"
                               FontWeight="Bold"
                               Foreground="#FF111827"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="{Binding PrimaryButtonText}"
                            Command="{Binding PrimaryCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Grid.Column="2"
                            Content="{Binding ResetButtonText}"
                            Command="{Binding ResetCommand}"
                            MinWidth="96"
                            MinHeight="42"
                            Padding="16,8" />
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding TimerStateLabel}"
                               Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="{Binding TimerStateText}"
                               FontSize="16"
                               Foreground="#FF374151"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding CompletedSessionsText}"
                               FontSize="16"
                               Foreground="#FF374151"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding ValidationErrorText}"
                               Style="{StaticResource ErrorTextStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
