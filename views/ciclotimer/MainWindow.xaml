<Window x:Class="CicloTimer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CicloTimer.Views.Controls"
        Title="{Binding AppTitle}"
        Width="460"
        Height="640"
        MinWidth="420"
        MinHeight="560"
        ResizeMode="CanMinimize"
        Background="#FFF4F7FB"
        Closed="Window_Closed"
        Loaded="Window_Loaded"
        KeyboardNavigation.TabNavigation="Cycle">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#FFE1E7EF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF243044" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9B1C1C" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasValidationError}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="22">
            <TextBlock Text="{Binding AppTitle}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#FF1F2937"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,18"
                       Focusable="False" />

            <Border Style="{StaticResource CardStyle}"
                    IsEnabled="{Binding CanEditConfiguration}">
                <StackPanel>
                    <TextBlock Text="{Binding SessionDurationLabel}"
                               Style="{StaticResource CardTitleStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <controls:NumericStepControl Grid.Column="0"
                                                     x:Name="SessionMinutesControl"
                                                     Label="{Binding MinutesLabel}"
                                                     AccessibleName="{Binding SessionDurationMinutesAccessibleName}"
                                                     Value="{Binding CycleMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Minimum="0"
                                                     Maximum="999"
                                                     Step="1"
                                                     TabIndex="0" />
                        <controls:NumericStepControl Grid.Column="2"
                                                     Label="{Binding SecondsLabel}"
                                                     AccessibleName="{Binding SessionDurationSecondsAccessibleName}"
                                                     Value="{Binding CycleSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Minimum="0"
                                                     Maximum="59"
                                                     Step="1"
                                                     TabIndex="1" />
                    </Grid>

                    <Separator Margin="0,16" />

                    <controls:NumericStepControl Label="{Binding FinalAlertDurationLabel}"
                                                 AccessibleName="{Binding FinalAlertDurationSecondsAccessibleName}"
                                                 Value="{Binding FinalAlertSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Minimum="0"
                                                 Maximum="60"
                                                 Step="1"
                                                 TabIndex="2" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding RemainingTimeLabel}"
                               Style="{StaticResource CardTitleStyle}"
                               HorizontalAlignment="Center"
                               Focusable="False" />
                    <TextBlock Text="{Binding RemainingTimeText}"
                               FontSize="54"
                               FontWeight="Bold"
                               Foreground="#FF111827"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"
                               AutomationProperties.Name="{Binding RemainingTimeLabel}"
                               AutomationProperties.LiveSetting="Off"
                               Focusable="False" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="{Binding PrimaryButtonText}"
                            Command="{Binding PrimaryCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            AutomationProperties.Name="{Binding PrimaryButtonText}"
                            TabIndex="3" />
                    <Button Grid.Column="2"
                            Content="{Binding ResetButtonText}"
                            Command="{Binding ResetCommand}"
                            MinWidth="96"
                            MinHeight="42"
                            Padding="16,8"
                            AutomationProperties.Name="{Binding ResetButtonText}"
                            TabIndex="4" />
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding TimerStateLabel}"
                               Style="{StaticResource CardTitleStyle}"
                               Focusable="False" />
                    <Label Content="Riepilogo timer"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#FF374151"
                           Margin="0,0,0,8"
                           AutomationProperties.Name="{Binding TimerAccessibilitySummary}"
                           AutomationProperties.LiveSetting="Off"
                           Focusable="True"
                           TabIndex="5" />
                    <TextBlock Text="{Binding TimerStateText}"
                               FontSize="16"
                               Foreground="#FF374151"
                               Margin="0,0,0,8"
                               AutomationProperties.Name="{Binding TimerStateLabel}"
                               Focusable="False" />
                    <TextBlock Text="{Binding CompletedSessionsText}"
                               FontSize="16"
                               Foreground="#FF374151"
                               Margin="0,0,0,8"
                               AutomationProperties.Name="{Binding CompletedSessionsLabel}"
                               Focusable="False" />
                    <TextBlock x:Name="EventMessageText"
                               Text="{Binding EventMessageText}"
                               FontSize="16"
                               Foreground="#FF374151"
                               Margin="0,0,0,8"
                               AutomationProperties.LiveSetting="Polite"
                               Focusable="False"
                               Visibility="{Binding HasEventMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Text="{Binding ValidationErrorText}"
                               Style="{StaticResource ErrorTextStyle}"
                               AutomationProperties.LiveSetting="Assertive"
                               Focusable="False" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
